# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
# plan-week makes 40+ sequential calls — use a fast model (llama3.2, qwen2.5:7b), not a large one
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Increase if using a slow model or Docker with limited GPU (seconds per request)
OLLAMA_TIMEOUT=120
MAX_CONTEXT_CHARS=12000

# Storage
MEALPREPPER_DATA_DIR=./data

# Family defaults (override in config/family.yaml)
DEFAULT_TIMEZONE=America/New_York

# SMS backend: console (dev) | twilio (production on Linux) | apple_shortcuts (macOS Shortcuts webhook)
SMS_BACKEND=console

# Twilio (when SMS_BACKEND=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# Apple Shortcuts webhook (macOS only — when SMS_BACKEND=apple_shortcuts)
APPLE_SHORTCUTS_WEBHOOK_URL=

# Communications
APPROVAL_REQUIRED=true
DAILY_REMINDER_HOUR=7
