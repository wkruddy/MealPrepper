# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
# plan-week makes 40+ sequential calls — use a fast model (qwen3:8b, qwen2.5:7b), not a large one
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Increase if using a slow model or Docker with limited GPU (seconds per request)
OLLAMA_TIMEOUT=180
MAX_CONTEXT_CHARS=12000

# Storage
MEALPREPPER_DATA_DIR=./data

# Family defaults (override in config/family.yaml)
DEFAULT_TIMEZONE=America/New_York

# Notifications — console (dev) | slack | discord | telegram | imessage (macOS Shortcuts)
# SMS_BACKEND is still accepted as an alias for COMMS_BACKEND
COMMS_BACKEND=console

# Slack — webhook for outbound + bot tokens for inbound (watch-messages)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Channel ID for #food (recommended) — bot listens here
SLACK_CHANNEL_ID=
# OAuth install to additional workspaces (mealprepper slack oauth-server)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# HTTPS callback URL — required for OAuth install (Slack rejects http:// redirect URLs).
# 1. Run: ngrok http 8787
# 2. Add the same URL under api.slack.com → OAuth & Permissions → Redirect URLs
# 3. Set here (must match exactly, including path /slack/oauth/callback):
SLACK_OAUTH_REDIRECT_URI=https://YOUR-SUBDOMAIN.ngrok-free.app/slack/oauth/callback

# Discord webhook
DISCORD_WEBHOOK_URL=
# Optional — reserved for future inbound bot
DISCORD_BOT_TOKEN=

# Telegram BotFather bot (optional — not required until you install Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# macOS iMessage via Shortcuts webhook (when COMMS_BACKEND=imessage)
APPLE_SHORTCUTS_WEBHOOK_URL=

# Communications
APPROVAL_REQUIRED=true
DAILY_REMINDER_HOUR=7
